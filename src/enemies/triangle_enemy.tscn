script/source = "extends Enemy

func _initialize_shape() -> void:
	super._initialize_shape()
	if damageable.hitbox_shape:
		damageable.hitbox_shape.shape.points[0] = Vector2(0, - enemy_size.y / 2)
		damageable.hitbox_shape.shape.points[1] = Vector2(- enemy_size.x / 2, enemy_size.y / 2)
		damageable.hitbox_shape.shape.points[2] = Vector2(enemy_size.x / 2, enemy_size.y / 2)
	if damageable.hurtbox_shape:
		damageable.hurtbox_shape.shape.points[0] = Vector2(0, - enemy_size.y / 2)
		damageable.hurtbox_shape.shape.points[1] = Vector2(- enemy_size.x / 2, enemy_size.y / 2)
		damageable.hurtbox_shape.shape.points[2] = Vector2(enemy_size.x / 2, enemy_size.y / 2)
"

